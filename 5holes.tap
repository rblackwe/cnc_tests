%
; ============================================================
; [JOB:PRODUCTION-HOLES]
; [TOOL:THE-BEAST-1_4-ROUGHING-UPCUT]
; [DATE:2026-04-26]
; [MATERIAL:UNKNOWN]
; [REVISION:2]
; ============================================================
; PURPOSE: Cut 5 holes all at 0.505" diameter, 0.510" deep.
;          0.505" confirmed best snug fit from test run.
;          Depth increased from 0.1" to 0.510" (just over 1/2")
;          Single pass - within Beast's 0.75" stepdown limit.
;
; STRATEGY: Tool center offset inward by tool radius (0.125")
;           from desired hole wall gives tool path radius of 0.1275"
;           Holes spaced 1" apart along X axis.
;           Z is left at cutting depth after last hole.
;           Machine returns to XY start after all holes are cut.
;
; TOOL SPECS:
;   [SPEC:NAME]         The Beast 1/4" Roughing Upcut
;   [SPEC:OVERALL-LEN]  2.5 in
;   [SPEC:FLUTE-LEN]    1 in
;   [SPEC:FLUTES]       3
;   [SPEC:SHANK-DIA]    0.25 in
;   [SPEC:CUT-DIA]      0.25 in
;   [SPEC:TOOL-RADIUS]  0.125 in
;
; CUT SETTINGS:
;   [SETTING:SPINDLE]   22000 RPM
;   [SETTING:FEED]      100 in/min
;   [SETTING:PLUNGE]    80 in/min
;   [SETTING:DEPTH]     0.510 in  <-- updated from 0.1"
;   [SETTING:STEPDOWN]  0.75 in   (0.510" fits in single pass)
;   [SETTING:STEPOVER]  0.2 in
;   [SETTING:CHIPLOAD]  0.0015 in
;
; HOLE SUMMARY:
;   [HOLE:1] Diameter 0.505" | Depth 0.510" | X offset 0"
;   [HOLE:2] Diameter 0.505" | Depth 0.510" | X offset 1"
;   [HOLE:3] Diameter 0.505" | Depth 0.510" | X offset 2"
;   [HOLE:4] Diameter 0.505" | Depth 0.510" | X offset 3"
;   [HOLE:5] Diameter 0.505" | Depth 0.510" | X offset 4"
;
; DIAMETER MATH:
;   Target diameter:  0.505"
;   Tool diameter:    0.250"
;   Tool radius:      0.125"
;   Tool path radius: (0.505 / 2) - 0.125 = 0.1275"
;
; DEPTH MATH:
;   Target depth:     0.510" (just over 1/2")
;   Beast stepdown:   0.750" (single pass is safe)
;   Beast flute len:  1.000" (0.510" well within flute length)
;
; SPACE REQUIRED: 5" clear in X from start position
;
; NOTE: Z is intentionally left at cutting depth (-0.510") after
;       last hole. Raise Z manually before repositioning.
; ============================================================

O0001

; --- MACHINE SETUP ---
G20   ; Work in inches (not mm)
G90   ; Start in absolute mode for clarity
G91   ; Switch to relative/incremental mode for all moves below

S22000  ; Set spindle speed to 22000 RPM
M3      ; Spindle ON, clockwise rotation
G4 P2   ; Dwell 2 seconds to let spindle reach full speed


; ============================================================
; [HOLE:1] DIAMETER: 0.505" | DEPTH: 0.510" | X OFFSET: 0"
; ============================================================
F80             ; Plunge feed rate (80 in/min)
G1 Z-0.510      ; Plunge down 0.510 inches in one pass
                ; Safe - within 0.75" stepdown limit
F100            ; Switch to lateral feed rate (100 in/min)
G1 X0.1275      ; Move to circle entry point (tool path radius)
G2 I-0.1275 J0  ; Full clockwise circle - center is 0.1275" left
G1 X-0.1275     ; Return tool center back to hole center
F80
G1 Z0.510       ; Lift full depth for safe travel to next hole
F100
G1 X1.0         ; Move 1" right to next hole center


; ============================================================
; [HOLE:2] DIAMETER: 0.505" | DEPTH: 0.510" | X OFFSET: 1"
; ============================================================
F80
G1 Z-0.510
F100
G1 X0.1275
G2 I-0.1275 J0
G1 X-0.1275
F80
G1 Z0.510
F100
G1 X1.0


; ============================================================
; [HOLE:3] DIAMETER: 0.505" | DEPTH: 0.510" | X OFFSET: 2"
; ============================================================
F80
G1 Z-0.510
F100
G1 X0.1275
G2 I-0.1275 J0
G1 X-0.1275
F80
G1 Z0.510
F100
G1 X1.0


; ============================================================
; [HOLE:4] DIAMETER: 0.505" | DEPTH: 0.510" | X OFFSET: 3"
; ============================================================
F80
G1 Z-0.510
F100
G1 X0.1275
G2 I-0.1275 J0
G1 X-0.1275
F80
G1 Z0.510
F100
G1 X1.0


; ============================================================
; [HOLE:5] DIAMETER: 0.505" | DEPTH: 0.510" | X OFFSET: 4"
; Last hole - no Z lift, leaving at cutting depth intentionally
; ============================================================
F80
G1 Z-0.510
F100
G1 X0.1275
G2 I-0.1275 J0
G1 X-0.1275     ; Return to center of last hole, no Z lift


; --- RETURN TO START ---
; Moved exactly 4.0" in X across 4 inter-hole gaps of 1" each
; Y never moved so no Y correction needed
; Z stays at -0.510" (cutting depth of last hole)
F100
G1 X-4.0        ; Return to original XY start position


; --- SHUTDOWN ---
M5    ; Spindle OFF
G90   ; Restore absolute positioning mode
M30   ; End program and rewind
%